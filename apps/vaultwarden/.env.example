# Vaultwarden configuration
# Copy to .env and set secure values before starting

# Optional timezone
TZ=UTC

# Public URL served by Traefik
VW_DOMAIN=https://vault.jr4.in

# Set to false after initial setup to close registrations
VW_SIGNUPS_ALLOWED=true

# Required for /admin access (generate a long random string)
VW_ADMIN_TOKEN=replace-with-a-long-random-secret
