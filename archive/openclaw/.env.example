# OpenClaw Configuration
# Copy this file to .env and fill in your API keys

# Gateway Security (generate a strong token)
OPENCLAW_GATEWAY_TOKEN=your-secure-random-token-here

# AI Provider API Keys (at least one required)
# OpenRouter (recommended for multiple models)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_HTTP_REFERER=https://claw.jr4.in
OPENROUTER_TITLE=OpenClaw

# Google AI (Gemini models)
GOOGLE_API_KEY=...

# NVIDIA API (for local/enterprise models)
NVIDIA_API_KEY=nvapi-...

# Optional: Timezone
# TZ=America/New_York
